{
  "name": "package-based",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "postinstall": "husky install",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\"",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" --ext .ts,.tsx --fix",
    "prepare": "husky",
    "generate-prisma": "npx prisma generate --schema=./packages/buildflex-server/src/modules/prisma/postgres/schema.prisma",
    "migrate-deploy": "npx prisma migrate deploy --schema=./packages/buildflex-server/src/modules/prisma/postgres/schema.prisma",
    "migrate-dev": "npx prisma migrate dev --schema=./packages/buildflex-server/src/modules/prisma/postgres/schema.prisma"
  },
